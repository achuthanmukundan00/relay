{
  "name": "relay",
  "version": "0.1.0",
  "description": "Lightweight OpenAI/Anthropic-compatible gateway for local llama.cpp models.",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm test && npm run typecheck",
    "doctor": "node --experimental-strip-types scripts/doctor.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
